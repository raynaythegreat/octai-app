{
  "identifier": "default",
  "description": "Default capability for OctAi",
  "windows": ["main"],
  "permissions": [
    {
      "identifier": "shell:allow-spawn",
      "allow": [
        {
          "name": "octai-backend",
          "cmd": "octai-backend",
          "args": true,
          "sidecar": true
        }
      ]
    },
    "core:default",
    "shell:allow-open",
    "shell:allow-kill",
    "shell:allow-stdin-write",
    "process:default",
    "notification:default",
    "updater:default",
    "autostart:default"
  ]
}
